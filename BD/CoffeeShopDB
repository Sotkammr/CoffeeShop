CREATE DATABASE CoffeeShopDB
USE CoffeeShopDB;
GO

CREATE TABLE Positions (
    Id_Position INT PRIMARY KEY IDENTITY(1,1),
    Name NVARCHAR(50) NOT NULL
);

CREATE TABLE Categories (
    Id_Category INT PRIMARY KEY IDENTITY(1,1),
    Name NVARCHAR(50) NOT NULL
);

CREATE TABLE PaymentMethods (
    Id_Method INT PRIMARY KEY IDENTITY(1,1),
    Name NVARCHAR(50) NOT NULL
);

CREATE TABLE Employees (
    Id_Employee INT PRIMARY KEY IDENTITY(1,1),
    Surname NVARCHAR(50) NOT NULL,
    Name NVARCHAR(50) NOT NULL,
    Patronymic NVARCHAR(50),
    Phone NVARCHAR(20),
    Email NVARCHAR(100),
    Id_Position INT,
    EmployeeCode NVARCHAR(20),
    HireDate DATETIME,
    IsActive BIT DEFAULT 1,
    FOREIGN KEY (Id_Position) REFERENCES Positions(Id_Position)
);

CREATE TABLE AuthData (
    Id_Auth INT PRIMARY KEY IDENTITY(1,1),
    Id_Employee INT,
    Login NVARCHAR(50) UNIQUE NOT NULL,
    Password NVARCHAR(50) NOT NULL,
    LastLoginDate DATETIME,
    FOREIGN KEY (Id_Employee) REFERENCES Employees(Id_Employee)
);

CREATE TABLE Products (
    Id_Product INT PRIMARY KEY IDENTITY(1,1),
    Name NVARCHAR(100) NOT NULL,
    Description NVARCHAR(MAX),
    Price DECIMAL(10,2) NOT NULL,
    Id_Category INT,
    QuantityInStock INT DEFAULT 100,
    IsActive BIT DEFAULT 1,
    FOREIGN KEY (Id_Category) REFERENCES Categories(Id_Category)
);

CREATE TABLE Sales (
    Id_Sale INT PRIMARY KEY IDENTITY(1,1),
    SaleNumber NVARCHAR(20) UNIQUE NOT NULL,
    SaleDate DATETIME NOT NULL,
    Id_Employee INT,
    Id_PaymentMethod INT,
    TotalAmount DECIMAL(10,2) NOT NULL,
    FinalAmount DECIMAL(10,2) NOT NULL,
    FOREIGN KEY (Id_Employee) REFERENCES Employees(Id_Employee),
    FOREIGN KEY (Id_PaymentMethod) REFERENCES PaymentMethods(Id_Method)
);

CREATE TABLE SaleItems (
    Id_Item INT PRIMARY KEY IDENTITY(1,1),
    Id_Sale INT,
    Id_Product INT,
    Quantity INT NOT NULL,
    Price DECIMAL(10,2) NOT NULL,
    Total DECIMAL(10,2) NOT NULL,
    FOREIGN KEY (Id_Sale) REFERENCES Sales(Id_Sale),
    FOREIGN KEY (Id_Product) REFERENCES Products(Id_Product)
);
GO
CREATE VIEW View_UserAuth AS
SELECT
    e.Id_Employee,
    e.Surname + ' ' + e.Name + ' ' + ISNULL(e.Patronymic, '') AS FullName,
    p.Name AS Position,
    a.Login,
    a.Password
FROM Employees e
JOIN AuthData a ON e.Id_Employee = a.Id_Employee
JOIN Positions p ON e.Id_Position = p.Id_Position
WHERE e.IsActive = 1;
GO
