<Window x:Class="CoffeeShop.Windows.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" 
        Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel>
            <Label Content="Данные товара" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Foreground="#795548"
                   Margin="0,0,0,20"/>

            <Label Content="Название товара:" FontWeight="Bold"/>
            <TextBox x:Name="txtName" 
                     Height="35" 
                     FontSize="14" 
                     Padding="5"
                     Margin="0,5,0,15"/>

            <Label Content="Цена:" FontWeight="Bold"/>
            <TextBox x:Name="txtPrice" 
                     Height="35" 
                     FontSize="14" 
                     Padding="5"
                     Margin="0,5,0,15"/>

            <Label Content="Категория:" FontWeight="Bold"/>
            <ComboBox x:Name="cmbCategory" 
                      Height="35" 
                      FontSize="14">
                <ComboBoxItem Content="Кофе" IsSelected="True"/>
                <ComboBoxItem Content="Чай"/>
                <ComboBoxItem Content="Выпечка"/>
                <ComboBoxItem Content="Десерты"/>
                <ComboBoxItem Content="Сэндвичи"/>
                <ComboBoxItem Content="Салаты"/>
                <ComboBoxItem Content="Напитки"/>
                <ComboBoxItem Content="Другое"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="0,25,0,0">
                <Button x:Name="btnCancel" 
                        Content="Отмена" 
                        Width="100" 
                        Height="40"
                        Background="#9E9E9E"
                        Foreground="White" 
                        FontWeight="Bold"
                        Click="btnCancel_Click"/>

                <Button x:Name="btnSave" 
                        Content="Сохранить" 
                        Width="100" 
                        Height="40" 
                        Background="#4CAF50" 
                        Foreground="White" 
                        FontWeight="Bold"
                        Margin="15,0,0,0"
                        Click="btnSave_Click"/>
            </StackPanel>
            <TextBlock x:Name="lblStatus" 
                       Foreground="Red" 
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Window>