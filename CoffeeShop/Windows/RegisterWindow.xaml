<Window x:Class="CoffeeShop.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация нового сотрудника" 
        Height="806" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="#F5F5F5">
        <Border Background="White" 
                CornerRadius="10" 
                Padding="30" 
                Margin="20">
            <StackPanel>
                <Label Content="Регистрация" 
                       FontSize="22" 
                       FontWeight="Bold" 
                       Foreground="#795548"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

                <Label Content="Логин:" FontWeight="Bold"/>
                <TextBox x:Name="txtLogin" 
                         Height="35" 
                         FontSize="14" 
                         Padding="5"
                         Margin="0,0,0,10"/>

                <Label Content="Пароль:" FontWeight="Bold"/>
                <PasswordBox x:Name="txtPassword" 
                             Height="35" 
                             FontSize="14" 
                             Padding="5"
                             Margin="0,0,0,10"/>

                <Label Content="Подтверждение пароля:" FontWeight="Bold"/>
                <PasswordBox x:Name="txtConfirmPassword" 
                             Height="35" 
                             FontSize="14" 
                             Padding="5"
                             Margin="0,0,0,10"/>

                <Label Content="ФИО сотрудника:" FontWeight="Bold"/>
                <TextBox x:Name="txtFullName" 
                         Height="35" 
                         FontSize="14" 
                         Padding="5"
                         Margin="0,0,0,10"/>

                <Label Content="Должность:" FontWeight="Bold"/>
                <ComboBox x:Name="cmbPosition" 
                          Height="35" 
                          FontSize="14"
                          Margin="0,0,0,10">
                    <ComboBoxItem Content="Бариста" IsSelected="True"/>
                    <ComboBoxItem Content="Кассир"/>
                    <ComboBoxItem Content="Старший смены"/>
                    <ComboBoxItem Content="Менеджер"/>
                    <ComboBoxItem Content="Администратор"/>
                </ComboBox>

                <Label Content="Телефон:" FontWeight="Bold"/>
                <TextBox x:Name="txtPhone" 
                         Height="35" 
                         FontSize="14" 
                         Padding="5"
                         Margin="0,0,0,10"/>

                <Label Content="Email:" FontWeight="Bold"/>
                <TextBox x:Name="txtEmail" 
                         Height="35" 
                         FontSize="14" 
                         Padding="5"
                         Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right">
                    <Button x:Name="btnCancel" 
                            Content="Отмена" 
                            Width="100" 
                            Height="40"
                            Background="#9E9E9E"
                            Foreground="White" 
                            FontWeight="Bold"
                            Click="btnCancel_Click"/>

                    <Button x:Name="btnRegister" 
                            Content="Зарегистрировать" 
                            Width="150" 
                            Height="40" 
                            Background="#4CAF50" 
                            Foreground="White" 
                            FontWeight="Bold"
                            Margin="15,0,0,0"
                            Click="btnRegister_Click"/>
                </StackPanel>

                <TextBlock x:Name="lblStatus" 
                           Foreground="Red" 
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>