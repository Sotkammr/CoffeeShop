<Page x:Class="CoffeeShop.Pages.SalesHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="История продаж">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="📊 ИСТОРИЯ ПРОДАЖ" 
                   FontSize="32" 
                   FontWeight="Bold" 
                   Foreground="#795548"
                   Margin="0,0,0,20"
                   HorizontalAlignment="Center"/>

        <Border Grid.Row="1" 
                Background="#F5F5F5" 
                Padding="20" 
                CornerRadius="10"
                Margin="0,0,0,20">
            <WrapPanel HorizontalAlignment="Center">
                <TextBlock Text="Период:" 
                           FontSize="16" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,20,5">
                    <TextBlock Text="От:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="14"/>
                    <DatePicker x:Name="dpFrom" Width="130" Height="35" FontSize="14"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,20,5">
                    <TextBlock Text="До:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="14"/>
                    <DatePicker x:Name="dpTo" Width="130" Height="35" FontSize="14"/>
                </StackPanel>

                <Button x:Name="btnToday" 
                        Content="Сегодня" 
                        Width="90" 
                        Height="35"
                        Background="#9E9E9E"
                        Foreground="White"
                        FontWeight="Bold"
                        Margin="0,0,5,5"
                        Click="btnToday_Click"/>

                <Button x:Name="btnWeek" 
                        Content="Неделя" 
                        Width="90" 
                        Height="35"
                        Background="#9E9E9E"
                        Foreground="White"
                        FontWeight="Bold"
                        Margin="0,0,5,5"
                        Click="btnWeek_Click"/>

                <Button x:Name="btnMonth" 
                        Content="Месяц" 
                        Width="90" 
                        Height="35"
                        Background="#9E9E9E"
                        Foreground="White"
                        FontWeight="Bold"
                        Margin="0,0,5,5"
                        Click="btnMonth_Click"/>

                <Button x:Name="btnLoad" 
                        Content="📅 Применить" 
                        Width="120" 
                        Height="35"
                        Background="#2196F3" 
                        Foreground="White"
                        FontWeight="Bold"
                        Margin="0,0,5,5"
                        Click="btnLoad_Click"/>

                <Button x:Name="btnExport" 
                        Content="📥 Экспорт CSV" 
                        Width="130" 
                        Height="35"
                        Background="#4CAF50" 
                        Foreground="White"
                        FontWeight="Bold"
                        Margin="0,0,0,5"
                        Click="btnExport_Click"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2" 
                Background="#E8F5E8" 
                Padding="20" 
                CornerRadius="10"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" Padding="20" CornerRadius="8" Margin="5">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📋 Продаж" Foreground="#757575" FontSize="16" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="lblTotalSales" Text="0" FontSize="36" FontWeight="Bold" Foreground="#2196F3" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" Padding="20" CornerRadius="8" Margin="5">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="💰 Сумма" Foreground="#757575" FontSize="16" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="lblTotalAmount" Text="0 руб" FontSize="28" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" Padding="20" CornerRadius="8" Margin="5">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📊 Средний" Foreground="#757575" FontSize="16" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="lblAverageSale" Text="0 руб" FontSize="28" FontWeight="Bold" Foreground="#FF9800" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="White" Padding="20" CornerRadius="8" Margin="5">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="💳 Популярно" Foreground="#757575" FontSize="16" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="lblPopularPayment" Text="-" FontSize="24" FontWeight="Bold" Foreground="#9C27B0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="3" 
                Background="White" 
                Padding="20" 
                CornerRadius="10">
            <DataGrid x:Name="dgSales" 
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding DateDisplay}" Width="150"/>
                    <DataGridTextColumn Header="Номер чека" Binding="{Binding SaleNumber}" Width="180"/>
                    <DataGridTextColumn Header="Кассир" Binding="{Binding Cashier}" Width="180"/>
                    <DataGridTextColumn Header="Товары" Binding="{Binding ItemsDisplay}" Width="*"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding TotalDisplay}" Width="150"/>
                    <DataGridTextColumn Header="Оплата" Binding="{Binding PaymentType}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</Page>
