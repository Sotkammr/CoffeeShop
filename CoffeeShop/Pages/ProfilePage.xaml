<Page x:Class="CoffeeShop.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мой профиль">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">

            <TextBlock Text="👤 МОЙ ПРОФИЛЬ" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="#795548"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" Padding="25" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Основная информация" 
                                   FontSize="20" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Логин:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtLogin" 
                                 Height="40" 
                                 FontSize="16"
                                 IsEnabled="False"
                                 Background="#F5F5F5"
                                 Margin="0,0,0,15"/>

                        <TextBlock Text="ФИО:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtFullName" 
                                 Height="40" 
                                 FontSize="16"
                                 Margin="0,0,0,15"/>

                        <TextBlock Text="Должность:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbPosition" 
                                  Height="40" 
                                  FontSize="16"
                                  Margin="0,0,0,15">
                            <ComboBoxItem Content="Администратор"/>
                            <ComboBoxItem Content="Бариста"/>
                            <ComboBoxItem Content="Кассир"/>
                            <ComboBoxItem Content="Менеджер"/>
                        </ComboBox>

                        <TextBlock Text="Новый пароль (необязательно):" FontWeight="Bold" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="txtNewPassword" 
                                     Height="40" 
                                     FontSize="16"
                                     Margin="0,0,0,15"/>

                        <TextBlock Text="Подтверждение пароля:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="txtConfirmPassword" 
                                     Height="40" 
                                     FontSize="16"
                                     Margin="0,0,0,15"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="White" Padding="25" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Контактная информация" 
                                   FontSize="20" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Телефон:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPhone" 
                                 Height="40" 
                                 FontSize="16"
                                 Margin="0,0,0,15"/>

                        <TextBlock Text="Email:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtEmail" 
                                 Height="40" 
                                 FontSize="16"
                                 Margin="0,0,0,15"/>

                        <Border Background="#F5F5F5" Padding="20" CornerRadius="8" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="📊 Моя статистика" 
                                           FontSize="18" 
                                           FontWeight="Bold"
                                           Margin="0,0,0,15"/>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Продаж:" FontSize="14"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="lblTotalSales" Text="0" FontWeight="Bold" FontSize="14"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="На сумму:" FontSize="14" Margin="0,10,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="lblTotalAmount" Text="0 руб" FontWeight="Bold" FontSize="14" Margin="0,10,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                <Button x:Name="btnCancel" 
                        Content="Отмена" 
                        Width="120" 
                        Height="45"
                        Background="#9E9E9E"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="16"
                        Margin="0,0,20,0"
                        Click="btnCancel_Click"/>

                <Button x:Name="btnSave" 
                        Content="Сохранить" 
                        Width="120" 
                        Height="45"
                        Background="#4CAF50"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="16"
                        Click="btnSave_Click"/>
            </StackPanel>
            <TextBlock x:Name="lblStatus" 
                       Foreground="Red" 
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"
                       FontSize="14"/>
        </StackPanel>
    </ScrollViewer>
</Page>