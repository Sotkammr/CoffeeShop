<Page x:Class="CoffeeShopSales.Pages.NewSalePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Новая продажа"
      Background="#F5F5F5">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="White" 
                CornerRadius="15" 
                Padding="20" 
                Margin="0,0,0,30">
            <TextBlock Text="🛒 НОВАЯ ПРОДАЖА" 
                       FontSize="36" 
                       FontWeight="Bold" 
                       Foreground="#795548"
                       HorizontalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" 
                    Background="White" 
                    CornerRadius="20" 
                    Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="📋 ДОСТУПНЫЕ ТОВАРЫ" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#4CAF50"
                               Margin="0,0,0,20"/>

                    <ListBox Grid.Row="1" 
                             x:Name="lstProducts" 
                             Height="400"
                             Margin="0,0,0,20"
                             SelectionChanged="lstProducts_SelectionChanged"
                             FontSize="14">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding Name}" 
                                               FontWeight="Bold" 
                                               FontSize="16"/>
                                    <TextBlock Text="{Binding Price, StringFormat='Цена: {0:C}'}" 
                                               Foreground="#2196F3"
                                               FontSize="14"/>
                                    <TextBlock Text="{Binding Category}" 
                                               Foreground="Gray" 
                                               FontStyle="Italic"
                                               FontSize="12"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Row="2" 
                            x:Name="btnAddToCart" 
                            Content="➕ ДОБАВИТЬ В ЧЕК" 
                            Height="60" 
                            FontSize="18"
                            FontWeight="Bold"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            IsEnabled="False"
                            Click="btnAddToCart_Click"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" 
                    Background="White" 
                    CornerRadius="20" 
                    Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="🧾 ТЕКУЩИЙ ЧЕК" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#FF9800"
                               Margin="0,0,0,20"/>

                    <DataGrid Grid.Row="1" 
                              x:Name="dgCart" 
                              AutoGenerateColumns="False" 
                              Height="350"
                              Margin="0,0,0,20"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              FontSize="14"
                              SelectionChanged="dgCart_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Товар" Binding="{Binding Name}" Width="*"/>

   
                            <DataGridTemplateColumn Header="Кол-во" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="-" 
                                                    Width="30" 
                                                    Height="30"
                                                    Background="#F44336"
                                                    Foreground="White"
                                                    FontWeight="Bold"
                                                    FontSize="16"
                                                    Click="DecreaseQuantity_Click"
                                                    Tag="{Binding}"/>
                                            <TextBlock Text="{Binding Quantity}" 
                                                       Width="40" 
                                                       TextAlignment="Center"
                                                       FontSize="16"
                                                       FontWeight="Bold"/>
                                            <Button Content="+" 
                                                    Width="30" 
                                                    Height="30"
                                                    Background="#4CAF50"
                                                    Foreground="White"
                                                    FontWeight="Bold"
                                                    FontSize="16"
                                                    Click="IncreaseQuantity_Click"
                                                    Tag="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Ползунок -->
                            <DataGridTemplateColumn Header=" " Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Slider Minimum="1" 
                                                Maximum="20" 
                                                Value="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="100"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                SmallChange="1"
                                                LargeChange="1"
                                                ValueChanged="QuantitySlider_ValueChanged"
                                                Tag="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Цена" Binding="{Binding PriceDisplay}" Width="100"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalDisplay}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,20">
                        <Button x:Name="btnRemoveFromCart" 
                                Content="🗑️ Удалить" 
                                Width="120" 
                                Height="45"
                                Background="#F44336"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="14"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,10,0"
                                IsEnabled="False"
                                Click="btnRemoveFromCart_Click"/>

                        <Button x:Name="btnClearCart" 
                                Content="🧹 Очистить" 
                                Width="120" 
                                Height="45"
                                Background="#FF9800"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="14"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="btnClearCart_Click"/>
                    </StackPanel>

                    <Border Grid.Row="3" 
                            Background="#F5F5F5" 
                            CornerRadius="15" 
                            Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="ИТОГО:" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       Foreground="#795548"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                       x:Name="lblTotal" 
                                       Text="0 руб" 
                                       FontSize="28" 
                                       FontWeight="Bold" 
                                       Foreground="#4CAF50"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,15,0"/>

                            <ComboBox Grid.Row="0" Grid.Column="2" 
                                      x:Name="cmbPaymentType" 
                                      Width="150" 
                                      Height="40"
                                      FontSize="14">
                                <ComboBoxItem Content="Наличные" IsSelected="True"/>
                                <ComboBoxItem Content="Карта"/>
                                <ComboBoxItem Content="Бесконтактно"/>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.ColumnSpan="3" 
                                       x:Name="txtSaleInfo" 
                                       Text="Добавьте товары в чек" 
                                       Foreground="#9E9E9E"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" 
                Background="#E3F2FD" 
                CornerRadius="15" 
                Padding="15"
                Margin="0,30,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="✅ ГОТОВО К ЗАВЕРШЕНИЮ" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="#1565C0"/>
                    <TextBlock x:Name="lblItemsCount" 
                               Text="0 товаров в чеке" 
                               FontSize="14" 
                               Foreground="#424242"/>
                </StackPanel>

                <Button Grid.Column="1" 
                        x:Name="btnCompleteSale" 
                        Content="✅ ЗАВЕРШИТЬ ПРОДАЖУ" 
                        Width="250" 
                        Height="60" 
                        Background="#2196F3" 
                        Foreground="White" 
                        FontWeight="Bold"
                        FontSize="18"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnCompleteSale_Click"/>
            </Grid>
        </Border>

    </Grid>
</Page>