<Page x:Class="CoffeeShop.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход в систему"
      Height="450" Width="400">
    <Grid Background="#F5F5F5">
        <Border Background="White" 
                CornerRadius="10" 
                Padding="30" 
                Width="350" 
                Height="400"
                VerticalAlignment="Center" 
                HorizontalAlignment="Center">
            <StackPanel>
                <StackPanel Margin="0,0,0,30">
                    <Label Content="☕ Кофейня" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#795548"
                           HorizontalAlignment="Center"/>
                    <Label Content="Система учета продаж" 
                           FontSize="16" 
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
                </StackPanel>

                <Label Content="Логин:" 
                       FontWeight="Bold"
                       Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogin" 
                         Height="35" 
                         FontSize="14"
                         Padding="5"/>

                <Label Content="Пароль:" 
                       FontWeight="Bold"
                       Margin="0,15,0,5"/>
                <PasswordBox x:Name="txtPassword" 
                             Height="35" 
                             FontSize="14"
                             Padding="5"/>

                <Button x:Name="btnLogin" 
                        Content="Войти" 
                        Height="40" 
                        Background="#795548" 
                        Foreground="White" 
                        FontWeight="Bold"
                        FontSize="16"
                        Margin="0,25,0,0"
                        Click="btnLogin_Click"/>

                <TextBlock x:Name="lblStatus" 
                           Foreground="Red" 
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>

                <Button x:Name="btnRegister" 
                        Content="Регистрация нового сотрудника" 
                        Height="35" 
                        Background="#2196F3" 
                        Foreground="White" 
                        FontWeight="Bold"
                        Margin="0,20,0,0"
                        Click="btnRegister_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>